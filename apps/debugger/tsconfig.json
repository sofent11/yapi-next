{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/*"],
      "@yapi-debugger/core": ["../../packages/debugger-core/src/index.ts"],
      "@yapi-debugger/importers": ["../../packages/debugger-importers/src/index.ts"],
      "@yapi-debugger/schema": ["../../packages/debugger-schema/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
